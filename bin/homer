#!/bin/sh
# homer — launch Homer for a GitHub pull request.
#   homer https://github.com/owner/repo/pull/N   → review that PR
# Opens a single window with three tabs (Activity · Guide · Diff),
# landing on Activity. A second `homer <pr-url>` while a window is open
# focuses it and points it at that PR.
#
# This is the DEV path: it runs Electron against this repo's built `out/`.
# The global-install path (packaged .app + a `homer` on PATH that launches
# it) is handled by scripts/install.sh (issue #35).
set -e
APP_DIR="$(cd "$(dirname "$0")/.." && pwd)"
if [ ! -f "$APP_DIR/out/main/index.js" ]; then
  echo "build not found. Run 'bun run build' in $APP_DIR first." >&2
  exit 1
fi
if [ -z "$1" ]; then
  echo "usage: homer <github-pr-url>" >&2
  exit 1
fi
exec "$APP_DIR/node_modules/.bin/electron" "$APP_DIR" "$1"
