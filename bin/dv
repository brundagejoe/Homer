#!/bin/sh
# dv — launch Diff Viewer for the current git repo.
# Requires a build at out/. Run `bun run build` first.
set -e
APP_DIR="$(cd "$(dirname "$0")/.." && pwd)"
if [ ! -f "$APP_DIR/out/main/index.js" ]; then
  echo "diff-viewer build not found. Run 'bun run build' in $APP_DIR first." >&2
  exit 1
fi
exec "$APP_DIR/node_modules/.bin/electron" "$APP_DIR" "$(pwd)"
