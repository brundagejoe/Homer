{
  "name": "homer",
  "productName": "Homer",
  "version": "0.1.0",
  "description": "Homer — a guided tour of a GitHub PR: an agent-generated scrollytelling story of the change, then a full diff review.",
  "author": "Joe Brundage <joe.brundage@neighbor.com>",
  "main": "./out/main/index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "test": "bun test",
    "dist": "bun run build && electron-builder"
  },
  "build": {
    "appId": "com.brundagejoe.homer",
    "productName": "Homer",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "dir"
      ],
      "identity": null
    },
    "dmg": {
      "title": "Homer ${version}"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development"
    }
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@octokit/rest": "^22.0.1",
    "@pierre/diffs": "^1.2.1",
    "@pierre/trees": "^1.0.0-beta.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  }
}
